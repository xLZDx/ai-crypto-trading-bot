# Настройки подключения к бирже
EXCHANGE_ID=binance

# ВАШИ КЛЮЧИ (Получите их в кабинете биржи)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Использовать ли тестовую сеть (Testnet) - виртуальные деньги
USE_TESTNET=True

# ────────────────────────────────────────────────────────────────────────
# Dashboard authentication (Phase A1, 2026-05-12)
# Set DASHBOARD_API_KEY to a long random string. The JS dashboard sends
# it as X-API-Key on every /api/* call. If unset, every protected route
# falls open — DO NOT deploy without this.
# ────────────────────────────────────────────────────────────────────────
# DASHBOARD_API_KEY=replace_with_long_random_string_64chars

# ────────────────────────────────────────────────────────────────────────
# Service bind hosts (Phase A2, 2026-05-12)
# Defaults are 127.0.0.1 — safe for single-machine operation.
# Set to 0.0.0.0 (or a specific LAN IP) for cluster mode, where the
# orchestrator on the master accepts inbound from worker laptops and
# each worker accepts inbound /restart calls from the master.
# ────────────────────────────────────────────────────────────────────────
# Master (single-machine):     leave commented; defaults to localhost.
# Master (cluster, accepts remote workers):
#     ORCHESTRATOR_BIND_HOST=0.0.0.0
# Worker laptop (cluster, e.g. Ivan):
#     WORKER_BIND_HOST=0.0.0.0
# Local monitor UI (almost never needs changing):
#     MONITOR_BIND_HOST=127.0.0.1
# Legacy FastAPI control plane (scheduled for removal in Phase A11):
#     CONTROL_API_HOST=127.0.0.1

# ────────────────────────────────────────────────────────────────────────
# ZMQ data-bus HMAC key (Phase A6, 2026-05-12)
# All processes that share the ZMQ pub/sub data bus must have the SAME
# ZMQ_BUS_KEY in .env. The dashboard subscribes to orderflow snapshots
# published by orderbook_collector — if the keys diverge, the
# subscriber rejects every envelope as forged. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, each process generates an ephemeral key and cross-process
# pub/sub fails silently (with a CRITICAL warning at startup).
# ────────────────────────────────────────────────────────────────────────
# ZMQ_BUS_KEY=replace_with_long_random_string_48chars

# ────────────────────────────────────────────────────────────────────────
# Model manifest HMAC key (Phase A8, 2026-05-12)
# Defense in depth on top of Phase A7's torch weights_only=True. Every
# joblib/torch model load checks the file's HMAC-SHA256 against the
# entry in models/manifest.json. A tampered model file fails the check
# and is refused. If MODEL_MANIFEST_KEY is unset, the check is bypassed
# (fail-open) with a one-shot WARNING — set this key in production.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# On first run, the manifest is empty: each training save populates it.
# ────────────────────────────────────────────────────────────────────────
# Note: do NOT reuse the same value as ZMQ_BUS_KEY or DASHBOARD_API_KEY —
# each key serves a different protocol; cross-protocol reuse weakens the
# threat boundary if one secret leaks.
# MODEL_MANIFEST_KEY=replace_with_long_random_string_48chars

# ────────────────────────────────────────────────────────────────────────
# Model HMAC enforcement mode (Phase 1b, 2026-05-14)
# Controls what happens on HMAC mismatch:
#   enforce (DEFAULT): mismatch -> ModelIntegrityError, model load refused
#   warn             : mismatch -> CRITICAL log but load proceeds
#                      Use ONLY during diagnostic / debugging. A one-shot
#                      CRITICAL fires on first read so the operator notices
#                      they're in warn mode. Switch back to enforce ASAP.
#   off              : skip HMAC computation entirely on verify
#                      Same effect as MODEL_MANIFEST_KEY unset, but the key
#                      stays set so sign_model still updates manifest on
#                      training save. Use for high-throughput inference
#                      benchmarks where the HMAC streaming cost matters.
# Malformed manifest entries ALWAYS raise regardless of mode (corruption).
# ────────────────────────────────────────────────────────────────────────
# MODEL_HMAC_ENFORCEMENT=enforce

# ────────────────────────────────────────────────────────────────────────
# Data quality enforcement (Phase 4, 2026-05-14)
# Pre-trainer schema + bounds + freshness validation via pandera.
# Catches the "trained on bad data" class of bugs (zero-volume gaps,
# negative prices, non-monotonic timestamps, single-bar 50%+ spikes).
# Hard failures raise DataQualityError -> trainer aborts cleanly.
#
#   enforce (DEFAULT): hard failures raise, soft warnings log
#   warn             : hard failures log CRITICAL + return; training
#                      still runs. Operator should fix the data + revert.
#   off              : skip validation entirely. Escape hatch only.
# ────────────────────────────────────────────────────────────────────────
# DATA_QUALITY_MODE=enforce

# ────────────────────────────────────────────────────────────────────────
# Concept drift enforcement (Phase 6, 2026-05-14)
# Pauses live trading when live feature distributions drift significantly
# from the training baseline (PSI ≥ 0.25 on a HARD feature).
# Thresholds: PSI 0.10 = warn, 0.25 = pause. Wasserstein 0.15 = warn.
#
#   enforce  : DriftPauseError raised on hard-feature drift; bot halts
#              new trade signals until operator resolves the flag
#   warn (DEFAULT): all drift logged WARNING; no pause
#   off      : skip drift checks entirely
#
# Hard features (label-correlated, trigger pause): ofi_z, funding_z,
# macd_hist, frac_diff_d40, atr_14, etc. — see DRIFT_HARD_FEATURES in
# src/risk/drift_psi.py. Operator can extend via:
#   DRIFT_HARD_FEATURES_EXTRA=feat1,feat2
# ────────────────────────────────────────────────────────────────────────
# LLM_DRIFT_PAUSE=warn
# DRIFT_HARD_FEATURES_EXTRA=
