# Настройки подключения к бирже
EXCHANGE_ID=binance

# ВАШИ КЛЮЧИ (Получите их в кабинете биржи)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Использовать ли тестовую сеть (Testnet) - виртуальные деньги
USE_TESTNET=True

# ────────────────────────────────────────────────────────────────────────
# Dashboard authentication (Phase A1, 2026-05-12)
# Set DASHBOARD_API_KEY to a long random string. The JS dashboard sends
# it as X-API-Key on every /api/* call. If unset, every protected route
# falls open — DO NOT deploy without this.
# ────────────────────────────────────────────────────────────────────────
# DASHBOARD_API_KEY=replace_with_long_random_string_64chars

# ────────────────────────────────────────────────────────────────────────
# Service bind hosts (Phase A2, 2026-05-12)
# Defaults are 127.0.0.1 — safe for single-machine operation.
# Set to 0.0.0.0 (or a specific LAN IP) for cluster mode, where the
# orchestrator on the master accepts inbound from worker laptops and
# each worker accepts inbound /restart calls from the master.
# ────────────────────────────────────────────────────────────────────────
# Master (single-machine):     leave commented; defaults to localhost.
# Master (cluster, accepts remote workers):
#     ORCHESTRATOR_BIND_HOST=0.0.0.0
# Worker laptop (cluster, e.g. Ivan):
#     WORKER_BIND_HOST=0.0.0.0
# Local monitor UI (almost never needs changing):
#     MONITOR_BIND_HOST=127.0.0.1
# Legacy FastAPI control plane (scheduled for removal in Phase A11):
#     CONTROL_API_HOST=127.0.0.1

# ────────────────────────────────────────────────────────────────────────
# ZMQ data-bus HMAC key (Phase A6, 2026-05-12)
# All processes that share the ZMQ pub/sub data bus must have the SAME
# ZMQ_BUS_KEY in .env. The dashboard subscribes to orderflow snapshots
# published by orderbook_collector — if the keys diverge, the
# subscriber rejects every envelope as forged. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, each process generates an ephemeral key and cross-process
# pub/sub fails silently (with a CRITICAL warning at startup).
# ────────────────────────────────────────────────────────────────────────
# ZMQ_BUS_KEY=replace_with_long_random_string_48chars
