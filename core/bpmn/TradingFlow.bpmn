<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_TradingFlow"
                  targetNamespace="http://aitrader.local/bpmn">
  <bpmn:process id="TradingFlow" name="Live trading — one WS tick to filled order" isExecutable="false">
    <bpmn:laneSet id="LaneSet_TradingFlow">
      <bpmn:lane id="Lane_Market" name="Market data (Binance WS)">
        <bpmn:flowNodeRef>Start_Tick</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Update</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Signal" name="Signal generation">
        <bpmn:flowNodeRef>Task_RawSig</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Meta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_MetaBlock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Spec" name="Market specialists (parallel)">
        <bpmn:flowNodeRef>GW_FanOut</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Spot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Fut</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Scalp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_FanIn</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Risk" name="Risk Agent (9-gate stack)">
        <bpmn:flowNodeRef>Task_9Gate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AllGates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RiskBlock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Exec" name="Execution + Kill Switch">
        <bpmn:flowNodeRef>GW_KS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Place</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_KSBlock</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Outcome" name="Order outcome">
        <bpmn:flowNodeRef>Task_Fill</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Done</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Tick" name="WS tick">
      <bpmn:outgoing>t1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Update" name="MarketAnalyzer
update state
+ regime">
      <bpmn:incoming>t1</bpmn:incoming>
      <bpmn:outgoing>t2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RawSig" name="SignalAgent
compute raw signal">
      <bpmn:incoming>t2</bpmn:incoming>
      <bpmn:outgoing>t3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_Meta" name="meta_pass?">
      <bpmn:incoming>t3</bpmn:incoming>
      <bpmn:outgoing>t4a</bpmn:outgoing>
      <bpmn:outgoing>t4b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_MetaBlock" name="blocked by
meta-labeler">
      <bpmn:incoming>t4a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:parallelGateway id="GW_FanOut" name="split">
      <bpmn:incoming>t4b</bpmn:incoming>
      <bpmn:outgoing>t5a</bpmn:outgoing>
      <bpmn:outgoing>t5b</bpmn:outgoing>
      <bpmn:outgoing>t5c</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_Spot" name="SpotAgent
conf &gt;= 0.62">
      <bpmn:incoming>t5a</bpmn:incoming>
      <bpmn:outgoing>t6a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Fut" name="FuturesAgent
funding + liq gates">
      <bpmn:incoming>t5b</bpmn:incoming>
      <bpmn:outgoing>t6b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Scalp" name="ScalpingAgent
ROUND_TRIP_FEE check">
      <bpmn:incoming>t5c</bpmn:incoming>
      <bpmn:outgoing>t6c</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_FanIn" name="join">
      <bpmn:incoming>t6a</bpmn:incoming>
      <bpmn:incoming>t6b</bpmn:incoming>
      <bpmn:incoming>t6c</bpmn:incoming>
      <bpmn:outgoing>t7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_9Gate" name="9-gate stack:
freshness → API latency →
circuit → drawdown → daily →
liquidity → β → LLM → Kelly">
      <bpmn:incoming>t7</bpmn:incoming>
      <bpmn:outgoing>t8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_AllGates" name="all gates pass?">
      <bpmn:incoming>t8</bpmn:incoming>
      <bpmn:outgoing>t9a</bpmn:outgoing>
      <bpmn:outgoing>t9b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_RiskBlock" name="blocked">
      <bpmn:incoming>t9a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_KS" name="KillSwitch
paused?">
      <bpmn:incoming>t9b</bpmn:incoming>
      <bpmn:outgoing>t10a</bpmn:outgoing>
      <bpmn:outgoing>t10b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Place" name="ExecutionAgent
place order on
Binance (CCXT)">
      <bpmn:incoming>t10b</bpmn:incoming>
      <bpmn:outgoing>t11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_KSBlock" name="blocked by
kill switch">
      <bpmn:incoming>t10a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_Fill" name="fill received
+ P&amp;L feedback
+ DB persist">
      <bpmn:incoming>t11</bpmn:incoming>
      <bpmn:outgoing>t12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Done" name="cycle complete">
      <bpmn:incoming>t12</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="t1" sourceRef="Start_Tick" targetRef="Task_Update" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t2" sourceRef="Task_Update" targetRef="Task_RawSig" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t3" sourceRef="Task_RawSig" targetRef="GW_Meta" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t4a" sourceRef="GW_Meta" targetRef="End_MetaBlock" name="BLOCK">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t4b" sourceRef="GW_Meta" targetRef="GW_FanOut" name="PASS">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t5a" sourceRef="GW_FanOut" targetRef="Task_Spot" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t5b" sourceRef="GW_FanOut" targetRef="Task_Fut" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t5c" sourceRef="GW_FanOut" targetRef="Task_Scalp" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t6a" sourceRef="Task_Spot" targetRef="GW_FanIn" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t6b" sourceRef="Task_Fut" targetRef="GW_FanIn" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t6c" sourceRef="Task_Scalp" targetRef="GW_FanIn" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t7" sourceRef="GW_FanIn" targetRef="Task_9Gate" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t8" sourceRef="Task_9Gate" targetRef="GW_AllGates" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t9a" sourceRef="GW_AllGates" targetRef="End_RiskBlock" name="any fail">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t9b" sourceRef="GW_AllGates" targetRef="GW_KS" name="all pass">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t10a" sourceRef="GW_KS" targetRef="End_KSBlock" name="paused">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t10b" sourceRef="GW_KS" targetRef="Task_Place" name="running">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t11" sourceRef="Task_Place" targetRef="Task_Fill" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="t12" sourceRef="Task_Fill" targetRef="End_Done" name="">
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_TradingFlow">
    <bpmndi:BPMNPlane id="Plane_TradingFlow" bpmnElement="TradingFlow">
    <bpmndi:BPMNShape id="Shape_Lane_Market" bpmnElement="Lane_Market" isHorizontal="true">
      <dc:Bounds x="0" y="0" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Lane_Signal" bpmnElement="Lane_Signal" isHorizontal="true">
      <dc:Bounds x="0" y="130" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Lane_Spec" bpmnElement="Lane_Spec" isHorizontal="true">
      <dc:Bounds x="0" y="260" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Lane_Risk" bpmnElement="Lane_Risk" isHorizontal="true">
      <dc:Bounds x="0" y="390" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Lane_Exec" bpmnElement="Lane_Exec" isHorizontal="true">
      <dc:Bounds x="0" y="520" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Lane_Outcome" bpmnElement="Lane_Outcome" isHorizontal="true">
      <dc:Bounds x="0" y="650" width="1730" height="130"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Start_Tick" bpmnElement="Start_Tick">
      <dc:Bounds x="60" y="47" width="36" height="36"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="40" y="87" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Update" bpmnElement="Task_Update">
      <dc:Bounds x="146" y="25" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_RawSig" bpmnElement="Task_RawSig">
      <dc:Bounds x="380" y="155" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_GW_Meta" bpmnElement="GW_Meta">
      <dc:Bounds x="540" y="170" width="50" height="50"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="520" y="224" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_End_MetaBlock" bpmnElement="End_MetaBlock">
      <dc:Bounds x="640" y="177" width="36" height="36"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="620" y="217" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_GW_FanOut" bpmnElement="GW_FanOut">
      <dc:Bounds x="860" y="300" width="50" height="50"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="840" y="354" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Spot" bpmnElement="Task_Spot">
      <dc:Bounds x="960" y="285" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Fut" bpmnElement="Task_Fut">
      <dc:Bounds x="1120" y="285" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Scalp" bpmnElement="Task_Scalp">
      <dc:Bounds x="1280" y="285" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_GW_FanIn" bpmnElement="GW_FanIn">
      <dc:Bounds x="1440" y="300" width="50" height="50"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="1420" y="354" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_9Gate" bpmnElement="Task_9Gate">
      <dc:Bounds x="1660" y="415" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_GW_AllGates" bpmnElement="GW_AllGates">
      <dc:Bounds x="1820" y="430" width="50" height="50"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="1800" y="484" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_End_RiskBlock" bpmnElement="End_RiskBlock">
      <dc:Bounds x="1920" y="437" width="36" height="36"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="1900" y="477" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_GW_KS" bpmnElement="GW_KS">
      <dc:Bounds x="2140" y="560" width="50" height="50"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="2120" y="614" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Place" bpmnElement="Task_Place">
      <dc:Bounds x="2240" y="545" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_End_KSBlock" bpmnElement="End_KSBlock">
      <dc:Bounds x="2400" y="567" width="36" height="36"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="2380" y="607" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_Task_Fill" bpmnElement="Task_Fill">
      <dc:Bounds x="2620" y="675" width="110" height="80"/>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="Shape_End_Done" bpmnElement="End_Done">
      <dc:Bounds x="2780" y="697" width="36" height="36"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="2760" y="737" width="110" height="22"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="Edge_t1" bpmnElement="t1">
      <di:waypoint x="96" y="65"/>
      <di:waypoint x="146" y="65"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t2" bpmnElement="t2">
      <di:waypoint x="256" y="65"/>
      <di:waypoint x="318" y="65"/>
      <di:waypoint x="318" y="195"/>
      <di:waypoint x="380" y="195"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t3" bpmnElement="t3">
      <di:waypoint x="490" y="195"/>
      <di:waypoint x="540" y="195"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t4a" bpmnElement="t4a">
      <di:waypoint x="590" y="195"/>
      <di:waypoint x="640" y="195"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="610" y="177" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t4b" bpmnElement="t4b">
      <di:waypoint x="590" y="195"/>
      <di:waypoint x="725" y="195"/>
      <di:waypoint x="725" y="325"/>
      <di:waypoint x="860" y="325"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="695" y="307" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t5a" bpmnElement="t5a">
      <di:waypoint x="910" y="325"/>
      <di:waypoint x="960" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t5b" bpmnElement="t5b">
      <di:waypoint x="910" y="325"/>
      <di:waypoint x="1120" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t5c" bpmnElement="t5c">
      <di:waypoint x="910" y="325"/>
      <di:waypoint x="1280" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t6a" bpmnElement="t6a">
      <di:waypoint x="1070" y="325"/>
      <di:waypoint x="1440" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t6b" bpmnElement="t6b">
      <di:waypoint x="1230" y="325"/>
      <di:waypoint x="1440" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t6c" bpmnElement="t6c">
      <di:waypoint x="1390" y="325"/>
      <di:waypoint x="1440" y="325"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t7" bpmnElement="t7">
      <di:waypoint x="1490" y="325"/>
      <di:waypoint x="1575" y="325"/>
      <di:waypoint x="1575" y="455"/>
      <di:waypoint x="1660" y="455"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t8" bpmnElement="t8">
      <di:waypoint x="1770" y="455"/>
      <di:waypoint x="1820" y="455"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t9a" bpmnElement="t9a">
      <di:waypoint x="1870" y="455"/>
      <di:waypoint x="1920" y="455"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="1890" y="437" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t9b" bpmnElement="t9b">
      <di:waypoint x="1870" y="455"/>
      <di:waypoint x="2005" y="455"/>
      <di:waypoint x="2005" y="585"/>
      <di:waypoint x="2140" y="585"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="1975" y="567" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t10a" bpmnElement="t10a">
      <di:waypoint x="2190" y="585"/>
      <di:waypoint x="2400" y="585"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="2370" y="567" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t10b" bpmnElement="t10b">
      <di:waypoint x="2190" y="585"/>
      <di:waypoint x="2240" y="585"/>
      <bpmndi:BPMNLabel>
        <dc:Bounds x="2210" y="567" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t11" bpmnElement="t11">
      <di:waypoint x="2350" y="585"/>
      <di:waypoint x="2485" y="585"/>
      <di:waypoint x="2485" y="715"/>
      <di:waypoint x="2620" y="715"/>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_t12" bpmnElement="t12">
      <di:waypoint x="2730" y="715"/>
      <di:waypoint x="2780" y="715"/>
    </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
