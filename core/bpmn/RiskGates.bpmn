<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_RiskGates"
                  targetNamespace="http://aitrader.local/bpmn">
  <bpmn:process id="RiskGates" name="RiskAgent — 9-gate stack traversal (fail-closed defaults)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_RiskGates">
      <bpmn:lane id="Lane_Bus" name="AgentBus (input)">
        <bpmn:flowNodeRef>Start_Sig</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MetaDir</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Pretrade" name="Pre-trade gates (1-3)">
        <bpmn:flowNodeRef>GW_G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_G2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_G3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DDgates" name="Drawdown gates (4-5)">
        <bpmn:flowNodeRef>GW_G4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_G5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Liquid" name="Liquidity + β gates (6-7)">
        <bpmn:flowNodeRef>GW_G6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_G7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_LLM" name="AgenticLLM macro veto (8)">
        <bpmn:flowNodeRef>Task_LLM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_G8</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Kelly" name="Kelly sizing (9)">
        <bpmn:flowNodeRef>Task_Kelly</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Order" name="Order publish">
        <bpmn:flowNodeRef>Task_PubOrder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Order</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Block" name="Block / kill paths">
        <bpmn:flowNodeRef>End_DropMeta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HardKill</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Block</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Sig" name="receive
&quot;trade_signal&quot;">
      <bpmn:outgoing>g1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_MetaDir" name="meta_pass=True AND
direction != 0?">
      <bpmn:incoming>g1</bpmn:incoming>
      <bpmn:outgoing>g2a</bpmn:outgoing>
      <bpmn:outgoing>g2b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_DropMeta" name="drop (no log)">
      <bpmn:incoming>g2a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_G1" name="G1: data_freshness
last bar ≤ 300s?
(DATA_STALE_SEC)">
      <bpmn:incoming>g2b</bpmn:incoming>
      <bpmn:outgoing>g3a</bpmn:outgoing>
      <bpmn:outgoing>g3b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G2" name="G2: API latency
p99 &lt; 500ms?
(API_LATENCY_LIMIT_MS)">
      <bpmn:incoming>g3b</bpmn:incoming>
      <bpmn:outgoing>g4a</bpmn:outgoing>
      <bpmn:outgoing>g4b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G3" name="G3: circuit breaker
&lt; 3 consec losses?
(MAX_CONSECUTIVE_LOSSES)">
      <bpmn:incoming>g4b</bpmn:incoming>
      <bpmn:outgoing>g5a</bpmn:outgoing>
      <bpmn:outgoing>g5b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G4" name="G4: cum drawdown
&lt; 10%?
(MAX_DRAWDOWN_PCT)">
      <bpmn:incoming>g5b</bpmn:incoming>
      <bpmn:outgoing>g6a</bpmn:outgoing>
      <bpmn:outgoing>g6b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_HardKill" name="_hard_kill()
publish &quot;risk_kill_switch&quot;
flatten_all
(STICKY pause)">
      <bpmn:incoming>g6a</bpmn:incoming>
      <bpmn:incoming>g8a</bpmn:incoming>
      <bpmn:outgoing>g7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_G5" name="G5: daily loss
&lt; 5%?
(MAX_DAILY_LOSS_PCT)">
      <bpmn:incoming>g6b</bpmn:incoming>
      <bpmn:outgoing>g8a</bpmn:outgoing>
      <bpmn:outgoing>g8b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G6" name="G6: liq_proximity
&lt; 0.85?
(LIQ_PROXIMITY_BLOCK)">
      <bpmn:incoming>g8b</bpmn:incoming>
      <bpmn:outgoing>g9a</bpmn:outgoing>
      <bpmn:outgoing>g9b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G7" name="G7: BetaFilter
would_breach
|β|_max = 1.0?">
      <bpmn:incoming>g9b</bpmn:incoming>
      <bpmn:outgoing>g10a</bpmn:outgoing>
      <bpmn:outgoing>g10b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_LLM" name="AgenticLLM.evaluate_trade
• 60s TTL decision cache
• threading.Lock + LRU 500
• 11-model fallback chain">
      <bpmn:incoming>g10b</bpmn:incoming>
      <bpmn:outgoing>g11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_G8" name="G8: LLM REJECTED?
(fail-OPEN on quota:
all cooled-down → APPROVED)">
      <bpmn:incoming>g11</bpmn:incoming>
      <bpmn:outgoing>g12a</bpmn:outgoing>
      <bpmn:outgoing>g12b</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Kelly" name="G9: kelly.size
• half_kelly = True
• window = 50 trades
• vol_scale × size_mult
  (regime-conditional)">
      <bpmn:incoming>g12b</bpmn:incoming>
      <bpmn:outgoing>g13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_PubOrder" name="publish &quot;order&quot;
{pending, size_usdt}">
      <bpmn:incoming>g13</bpmn:incoming>
      <bpmn:outgoing>g14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Order" name="order dispatched to
ExecutionAgent">
      <bpmn:incoming>g14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Block" name="BLOCKED">
      <bpmn:incoming>g3a</bpmn:incoming>
      <bpmn:incoming>g4a</bpmn:incoming>
      <bpmn:incoming>g5a</bpmn:incoming>
      <bpmn:incoming>g7</bpmn:incoming>
      <bpmn:incoming>g9a</bpmn:incoming>
      <bpmn:incoming>g10a</bpmn:incoming>
      <bpmn:incoming>g12a</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="g1" sourceRef="Start_Sig" targetRef="GW_MetaDir" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g2a" sourceRef="GW_MetaDir" targetRef="End_DropMeta" name="no">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g2b" sourceRef="GW_MetaDir" targetRef="GW_G1" name="yes">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g3a" sourceRef="GW_G1" targetRef="End_Block" name="stale">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g3b" sourceRef="GW_G1" targetRef="GW_G2" name="fresh">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g4a" sourceRef="GW_G2" targetRef="End_Block" name="slow">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g4b" sourceRef="GW_G2" targetRef="GW_G3" name="fast">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g5a" sourceRef="GW_G3" targetRef="End_Block" name="open">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g5b" sourceRef="GW_G3" targetRef="GW_G4" name="closed">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g6a" sourceRef="GW_G4" targetRef="Task_HardKill" name="breach">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g6b" sourceRef="GW_G4" targetRef="GW_G5" name="ok">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g7" sourceRef="Task_HardKill" targetRef="End_Block" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g8a" sourceRef="GW_G5" targetRef="Task_HardKill" name="breach">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g8b" sourceRef="GW_G5" targetRef="GW_G6" name="ok">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g9a" sourceRef="GW_G6" targetRef="End_Block" name="close to liq">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g9b" sourceRef="GW_G6" targetRef="GW_G7" name="clear">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g10a" sourceRef="GW_G7" targetRef="End_Block" name="|β| breach">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g10b" sourceRef="GW_G7" targetRef="Task_LLM" name="ok">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g11" sourceRef="Task_LLM" targetRef="GW_G8" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g12a" sourceRef="GW_G8" targetRef="End_Block" name="REJECTED">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g12b" sourceRef="GW_G8" targetRef="Task_Kelly" name="APPROVED">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g13" sourceRef="Task_Kelly" targetRef="Task_PubOrder" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="g14" sourceRef="Task_PubOrder" targetRef="End_Order" name="">
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_RiskGates">
    <bpmndi:BPMNPlane id="Plane_RiskGates" bpmnElement="RiskGates">
    <bpmndi:BPMNShape id="Shape_Lane_Bus" bpmnElement="Lane_Bus" isHorizontal="true">
