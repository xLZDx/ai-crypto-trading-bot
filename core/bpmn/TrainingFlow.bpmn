      <bpmndi:BPMNLabel>
        <dc:Bounds x="935" y="567" width="80" height="14"/>
      </bpmndi:BPMNLabel>
    </bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="Edge_f6" bpmnElement="f6">
      <di:waypoint x="1290" y="585"/>
