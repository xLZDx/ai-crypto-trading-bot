<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_InfraStartup"
                  targetNamespace="http://aitrader.local/bpmn">
  <bpmn:process id="InfraStartup" name="Infrastructure startup — restart_all.ps1 to 11 roles claimed" isExecutable="false">
    <bpmn:laneSet id="LaneSet_InfraStartup">
      <bpmn:lane id="Lane_Op" name="Operator">
        <bpmn:flowNodeRef>Start_Boot</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Script" name="restart_all.ps1">
        <bpmn:flowNodeRef>GW_FanOut1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_FanIn1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_FanOut2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_FanIn2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Preflight" name="Pre-flight (early-kill + recovery)">
        <bpmn:flowNodeRef>Task_EarlyKill</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Parquet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Recovery</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Tier1" name="Tier-1 processes (operational)">
        <bpmn:flowNodeRef>Task_Monitor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Cluster</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Dash</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Bot</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OB</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Tier2" name="Tier-2 processes (ancillary)">
        <bpmn:flowNodeRef>Task_OBW</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WLD</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DOR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DEB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DW</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SW</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Done" name="System ready">
        <bpmn:flowNodeRef>End_Ready</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Boot" name="operator runs
restart_all.ps1">
      <bpmn:outgoing>s1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_EarlyKill" name="Early-kill pre-step:
Stop-Process bot/dash/
orderbook_collector/...">
      <bpmn:incoming>s1</bpmn:incoming>
      <bpmn:outgoing>s2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Parquet" name="Parquet store check
(DuckDB import + dir)">
      <bpmn:incoming>s2</bpmn:incoming>
      <bpmn:outgoing>s3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Recovery" name="startup_recovery
--archive-only
(5-min cap)">
      <bpmn:incoming>s3</bpmn:incoming>
      <bpmn:outgoing>s4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_FanOut1" name="spawn Tier-1">
      <bpmn:incoming>s4</bpmn:incoming>
      <bpmn:outgoing>s5a</bpmn:outgoing>
      <bpmn:outgoing>s5b</bpmn:outgoing>
      <bpmn:outgoing>s5c</bpmn:outgoing>
      <bpmn:outgoing>s5d</bpmn:outgoing>
      <bpmn:outgoing>s5e</bpmn:outgoing>
      <bpmn:outgoing>s5f</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_Monitor" name="monitor :5001">
      <bpmn:incoming>s5a</bpmn:incoming>
      <bpmn:outgoing>s6a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Cluster" name="cluster_orch :7700">
      <bpmn:incoming>s5b</bpmn:incoming>
      <bpmn:outgoing>s6b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Dash" name="dashboard :5000">
      <bpmn:incoming>s5c</bpmn:incoming>
      <bpmn:outgoing>s6c</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Bot" name="bot (src.main)">
      <bpmn:incoming>s5d</bpmn:incoming>
      <bpmn:outgoing>s6d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RT" name="realtime_db_writer">
      <bpmn:incoming>s5e</bpmn:incoming>
      <bpmn:outgoing>s6e</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_OB" name="orderbook_collector">
      <bpmn:incoming>s5f</bpmn:incoming>
      <bpmn:outgoing>s6f</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_FanIn1" name="tier-1 ready">
      <bpmn:incoming>s6a</bpmn:incoming>
      <bpmn:incoming>s6b</bpmn:incoming>
      <bpmn:incoming>s6c</bpmn:incoming>
      <bpmn:incoming>s6d</bpmn:incoming>
      <bpmn:incoming>s6e</bpmn:incoming>
      <bpmn:incoming>s6f</bpmn:incoming>
      <bpmn:outgoing>s7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:parallelGateway id="GW_FanOut2" name="spawn Tier-2">
      <bpmn:incoming>s7</bpmn:incoming>
      <bpmn:outgoing>s8a</bpmn:outgoing>
      <bpmn:outgoing>s8b</bpmn:outgoing>
      <bpmn:outgoing>s8c</bpmn:outgoing>
      <bpmn:outgoing>s8d</bpmn:outgoing>
      <bpmn:outgoing>s8e</bpmn:outgoing>
      <bpmn:outgoing>s8f</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_OBW" name="orderbook_writer
(X1.2)">
      <bpmn:incoming>s8a</bpmn:incoming>
      <bpmn:outgoing>s9a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_WLD" name="watchlist_downloader">
      <bpmn:incoming>s8b</bpmn:incoming>
      <bpmn:outgoing>s9b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DOR" name="data_orchestrator">
      <bpmn:incoming>s8c</bpmn:incoming>
      <bpmn:outgoing>s9c</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DEB" name="debug_supervisor">
      <bpmn:incoming>s8d</bpmn:incoming>
      <bpmn:outgoing>s9d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DW" name="dashboard_watchdog">
      <bpmn:incoming>s8e</bpmn:incoming>
      <bpmn:outgoing>s9e</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SW" name="sweep_watchdog">
      <bpmn:incoming>s8f</bpmn:incoming>
      <bpmn:outgoing>s9f</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_FanIn2" name="all 11 spawned">
      <bpmn:incoming>s9a</bpmn:incoming>
      <bpmn:incoming>s9b</bpmn:incoming>
      <bpmn:incoming>s9c</bpmn:incoming>
      <bpmn:incoming>s9d</bpmn:incoming>
      <bpmn:incoming>s9e</bpmn:incoming>
      <bpmn:incoming>s9f</bpmn:incoming>
      <bpmn:outgoing>s10</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="End_Ready" name="11 roles claimed
in process_registry">
      <bpmn:incoming>s10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="s1" sourceRef="Start_Boot" targetRef="Task_EarlyKill" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s2" sourceRef="Task_EarlyKill" targetRef="Task_Parquet" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s3" sourceRef="Task_Parquet" targetRef="Task_Recovery" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s4" sourceRef="Task_Recovery" targetRef="GW_FanOut1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5a" sourceRef="GW_FanOut1" targetRef="Task_Monitor" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5b" sourceRef="GW_FanOut1" targetRef="Task_Cluster" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5c" sourceRef="GW_FanOut1" targetRef="Task_Dash" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5d" sourceRef="GW_FanOut1" targetRef="Task_Bot" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5e" sourceRef="GW_FanOut1" targetRef="Task_RT" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s5f" sourceRef="GW_FanOut1" targetRef="Task_OB" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6a" sourceRef="Task_Monitor" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6b" sourceRef="Task_Cluster" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6c" sourceRef="Task_Dash" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6d" sourceRef="Task_Bot" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6e" sourceRef="Task_RT" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s6f" sourceRef="Task_OB" targetRef="GW_FanIn1" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s7" sourceRef="GW_FanIn1" targetRef="GW_FanOut2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8a" sourceRef="GW_FanOut2" targetRef="Task_OBW" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8b" sourceRef="GW_FanOut2" targetRef="Task_WLD" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8c" sourceRef="GW_FanOut2" targetRef="Task_DOR" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8d" sourceRef="GW_FanOut2" targetRef="Task_DEB" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8e" sourceRef="GW_FanOut2" targetRef="Task_DW" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s8f" sourceRef="GW_FanOut2" targetRef="Task_SW" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9a" sourceRef="Task_OBW" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9b" sourceRef="Task_WLD" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9c" sourceRef="Task_DOR" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9d" sourceRef="Task_DEB" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9e" sourceRef="Task_DW" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s9f" sourceRef="Task_SW" targetRef="GW_FanIn2" name="">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s10" sourceRef="GW_FanIn2" targetRef="End_Ready" name="">
    </bpmn:sequenceFlow>
  </bpmn:process>
